# ─── Local development (without Docker) ──────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/carkhodro?schema=public"

# ─── Docker Compose credentials (read by docker-compose.yml) ─────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=carkhodro
DB_PORT=5432

# ─── Application ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Secret used to HMAC-hash OTP codes and sign the short-lived "verified phone"
# token. Generate with: openssl rand -base64 32
SESSION_SECRET="change_me_with_openssl_rand_base64_32"

# ─── SMS — IranPayamak / FarazSMS (OTP login + admin bulk marketing) ─────────
# Docs: https://docs.iranpayamak.com/
#
# Console / testing mode (no real SMS):
#   Set SMS_API_KEY="console" (or leave empty / SMS_API_KEY=console).
#   OTP codes are returned to the login UI and shown via browser alert;
#   bulk admin SMS is logged to the server console only.
#
# Production:
#   SMS_API_KEY            — Api-Key header from IranPayamak panel
#   SMS_LINE_NUMBER        — sender line (e.g. from GET /ws/v1/lines/accessible)
#   SMS_OTP_PATTERN_CODE   — approved pattern UID for login OTP (panel → Patterns)
#   SMS_OTP_PATTERN_ATTR   — variable name inside the pattern text (default: code)
#                            e.g. pattern "کد ورود: %code%" → attr "code"
SMS_API_KEY="console"
SMS_LINE_NUMBER=""
SMS_OTP_PATTERN_CODE=""
SMS_OTP_PATTERN_ATTR="code"

# ─── Admin panel seed account ─────────────────────────────────────────────────
# Used only by `prisma/seed.ts` to create the initial ADMIN login for `/admin`.
# Change the password after first login; re-running the seed never overwrites
# an existing admin.
ADMIN_SEED_USERNAME="admin"
ADMIN_SEED_PASSWORD="change_me_admin_password"

# ─── Hesabfa accounting sync ─────────────────────────────────────────────────
# Credentials are sent in each request body (apiKey + loginToken). Get them from
# Hesabfa → settings → API. The base URL rarely changes; override only if needed.
HESABFA_API_URL="https://api.hesabfa.com/v1"
HESABFA_API_KEY=""
HESABFA_LOGIN_TOKEN=""
# Shared secret echoed back in every webhook payload's `Password` field — the
# only authenticity check Hesabfa offers. Generate with: openssl rand -hex 24
# Used both to register the hook (registerHesabfaWebhook) and to verify inbound
# calls at /api/hesabfa/webhook. Must match what you register with Hesabfa.
HESABFA_HOOK_PASSWORD=""

# ─── Zibal payment gateway (IPG) ─────────────────────────────────────────────
# Merchant code from the Zibal panel. Use `zibal` for sandbox / test payments.
ZIBAL_MERCHANT="zibal"
