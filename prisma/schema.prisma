// ─────────────────────────────────────────────────────────────────────────────
// Carkhodro — Auto Spare Parts E-Commerce
// PostgreSQL · Prisma ORM
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output = "../generated/prisma_client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  RETAIL
  WHOLESALE
  ADMIN    // full back-office access
  SUPPORT  // read-only order/customer access
}

/// Audience filter for a bulk SMS blast — mirrors the RETAIL/WHOLESALE split
/// used everywhere else for pricing, with ALL meaning both.
enum SmsTargetRole {
  RETAIL
  WHOLESALE
  ALL
}

enum SmsCampaignStatus {
  PENDING
  SENT
  PARTIAL  // some recipients failed
  FAILED
}

/// Wholesale-order lifecycle, surfaced in the partner dashboard's order list and
/// status filter. Ordered roughly by progression; cancellation/archive are
/// terminal side-states. Persian labels live in `src/lib/order-labels.ts`.
enum OrderStatus {
  NEW                        // سفارش جدید — just submitted
  AWAITING_CONFIRMATION      // در انتظار تایید — pending shop review
  CONFIRMED_AWAITING_PAYMENT // تایید شده و در انتظار پرداخت
  PAID                       // پرداخت شده توسط مشتری
  SHIPPED                    // ارسال سفارش — handed to carrier
  COMPLETED                  // اتمام فاکتور — invoice closed
  CANCELLED_BY_CUSTOMER      // لغو شده توسط مشتری
  CANCELLED_BY_MANAGER       // لغو توسط مدیرفروشگاه
  ARCHIVED                   // آرشیو
}

/// Direction of a support message relative to the partner (who owns the thread).
enum MessageDirection {
  INBOUND  // received by the partner (sent by the support desk)
  OUTBOUND // sent by the partner to support
}

enum PaymentMethod {
  ONLINE  // IPG redirect
  COD     // cash on delivery
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ShippingMethod {
  STANDARD    // post — 3-5 business days
  EXPRESS     // 1-2 business days
}

// ─────────────────────────────────────────────────────────────────────────────
// REFERENCE DATA
// ─────────────────────────────────────────────────────────────────────────────

/// The 31 Iranian provinces — seeded once; never deleted.
model Province {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  cities City[]

  @@map("provinces")
}

/// Cities nested under a province — seeded from a standard list; admin can add more.
model City {
  id         Int      @id @default(autoincrement())
  provinceId Int      @map("province_id")
  name       String
  createdAt  DateTime @default(now()) @map("created_at")

  province  Province  @relation(fields: [provinceId], references: [id])
  addresses Address[]

  @@unique([provinceId, name])
  @@index([provinceId])
  @@map("cities")
}

/// Top-level navigation links — managed by admin; front end caches and revalidates.
model NavLink {
  id        Int      @id @default(autoincrement())
  href      String   @unique
  label     String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("nav_links")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTHENTICATION
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  /// Iranian mobile format: 09XXXXXXXXX (11 digits)
  phoneNumber  String   @unique @map("phone_number")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(RETAIL)
  /// Set to true after the first successful OTP verification
  isVerified   Boolean  @default(false) @map("is_verified")
  /// Wholesale customers must supply a shop/business name
  shopName     String?  @map("shop_name")
  birthDate    DateTime? @map("birth_date")
  profileImage String?  @map("profile_image")
  /// Partner's running ledger balance with the shop, in the same magnitude as
  /// product prices (Toman). Shown as «مانده حساب» on the dashboard.
  accountBalance BigInt @default(0) @map("account_balance")
  /// Who referred this partner («معرف») — free text captured on the profile.
  referredBy   String?  @map("referred_by")
  /// The partner's line of business («زمینه فعالیت») — free text.
  activityField String? @map("activity_field")
  /// Short, unique partner/affiliate code («کد اختصاصی») — null for retail users.
  partnerCode  String?  @unique @map("partner_code")
  /// Admin login username — only set for ADMIN-role users; storefront customers
  /// authenticate with SMS OTP and never get one.
  username     String?  @unique
  /// Scrypt password hash — only set for admin/back-office logins (ADMIN role).
  /// Storefront customers keep authenticating with SMS OTP and never get one.
  passwordHash String?  @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  addresses         Address[]
  sessions          Session[]
  orders            Order[]
  reviews           Review[]
  cart              Cart?
  wishlist          WishlistItem[]
  compareItems      CompareItem[]
  supportMessages     SupportMessage[]
  orderSurveys        OrderSurvey[]
  priceListRequests   PriceListRequest[]
  productSuggestions  ProductSuggestion[]
  smsCampaigns        SmsCampaign[]

  @@index([phoneNumber])
  @@map("users")
}

/// One active OTP per phone number — upserted on every send request.
model OtpSession {
  id          String   @id @default(cuid())
  phoneNumber String   @unique @map("phone_number")
  /// Bcrypt-hashed in production; store plain only in dev/test
  codeHash    String   @map("code_hash")
  /// Hard cutoff — reject even if code matches after this time
  expiresAt   DateTime @map("expires_at")
  /// Count repeated send attempts to enable rate-limiting
  attempts    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phoneNumber])
  @@map("otp_sessions")
}

/// Server-issued session token — created after OTP is consumed.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// User delivery addresses — one user may save many; at most one isDefault.
model Address {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  cityId     Int      @map("city_id")
  street     String
  postalCode String   @map("postal_code")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  city   City    @relation(fields: [cityId], references: [id])
  orders Order[]

  @@index([userId])
  @@index([cityId])
  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────────────────────
// CATALOGUE — CAR TAXONOMY
// ─────────────────────────────────────────────────────────────────────────────

/// Automobile manufacturers: ایران‌خودرو, سایپا, تویوتا, …
model CarBrand {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  /// URL-safe slug, e.g. "iran-khodro"
  slug         String   @unique
  logoImage    String?  @map("logo_image")
  /// Denormalized counter — refreshed by a background job or DB trigger
  productCount Int      @default(0) @map("product_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  carModels CarModel[]

  @@map("car_brands")
}

/// Specific car models — FK carBrandId → car_brands.id
model CarModel {
  id         Int      @id @default(autoincrement())
  carBrandId Int      @map("car_brand_id")
  name       String
  /// Gregorian year production began (null = unknown)
  yearStart  Int?     @map("year_start")
  /// Gregorian year production ended (null = still in production)
  yearEnd    Int?     @map("year_end")
  image      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  carBrand        CarBrand               @relation(fields: [carBrandId], references: [id])
  compatibilities ProductCompatibility[]

  @@index([carBrandId])
  @@map("car_models")
}

// ─────────────────────────────────────────────────────────────────────────────
// CATALOGUE — PARTS
// ─────────────────────────────────────────────────────────────────────────────

/// Spare-parts suppliers / manufacturers: بوش, NGK, ایساکو, …
/// Distinct from CarBrand — a Bosch brake pad fits a Toyota, not made by Toyota.
model PartsBrand {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  logoImage String?  @map("logo_image")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("parts_brands")
}

/// Product category: موتور و قطعات, ترمز و تعلیق, برق و روشنایی, …
model Category {
  id           Int      @id @default(autoincrement())
  /// URL / filter slug, e.g. "engine", "brake"
  key          String   @unique
  name         String
  image        String   @default("/logo.png")
  sortOrder    Int      @default(0) @map("sort_order")
  /// Denormalized counter — refreshed by a background job or DB trigger
  productCount Int      @default(0) @map("product_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id           String @id @default(cuid())
  /// Human-readable part number, e.g. "BSH-ENG-206-001"
  sku          String @unique
  name         String
  partsBrandId Int    @map("parts_brand_id")
  categoryId   Int    @map("category_id")

  // ── Pricing ────────────────────────────────────────────────────────────────
  /// Base wholesale price in Toman — synced from Hesabfa (SellPrice).
  wholesalePrice       BigInt   @map("wholesale_price")
  /// Percentage deducted for WHOLESALE users (0–100).
  /// wholesaleFinal = wholesalePrice × (1 − wholesaleDiscountPct / 100)
  wholesaleDiscountPct Decimal  @default(0) @map("wholesale_discount_pct") @db.Decimal(5, 2)
  /// Percentage added to wholesalePrice to derive the retail list price (1–100).
  /// retailPrice = wholesalePrice × (1 + retailPriceDiffPct / 100)
  retailPriceDiffPct   Decimal  @default(25) @map("retail_price_diff_pct") @db.Decimal(5, 2)
  /// Percentage deducted from retailPrice for RETAIL users (0–100).
  /// retailFinal = retailPrice × (1 − retailDiscountPct / 100)
  retailDiscountPct    Decimal  @default(0) @map("retail_discount_pct") @db.Decimal(5, 2)
  isOffer              Boolean  @default(false) @map("is_offer")

  // ── External accounting / ERP sync ────────────────────────────────────────
  /// Primary key in the external accountancy system.
  /// Nullable until first sync — product must not go live until populated.
  accountancyId String?  @unique @map("accountancy_id")
  /// Timestamp of the last successful price + stock pull from the external API
  lastSyncedAt  DateTime? @map("last_synced_at")

  // ── Inventory — synced from accountancy API ───────────────────────────────
  stock Int @default(0)

  // ── Physical / logistics details (managed by local admin) ─────────────────
  /// Country of origin, e.g. "آلمان", "ژاپن", "ایران"
  origin         String?
  /// Units per retail pack (e.g. spark plugs come in sets of 4)
  packQuantity   Int     @default(1) @map("pack_quantity")
  /// Retail packs per master carton — for wholesale order sizing
  cartonQuantity Int     @default(1) @map("carton_quantity")
  /// true = OEM / genuine part; false = aftermarket
  isOriginal     Boolean @default(true) @map("is_original")

  // ── Content (managed by local admin) ──────────────────────────────────────
  mainImage   String? @map("main_image")
  description String? @db.Text

  // ── Fuzzy full-text search ────────────────────────────────────────────────
  /// Denormalized, normalized search document (name + sku + origin + parts-brand
  /// + category + compatible car models). DB-maintained via triggers — never
  /// written from application code. Queried with pg_trgm for typo-tolerant search.
  searchText String? @map("search_text")

  // ── Analytics ──────────────────────────────────────────────────────────────
  viewCount   Int     @default(0) @map("view_count")
  saleCount   Int     @default(0) @map("sale_count")
  /// Denormalized average star rating (1.00–5.00) — recomputed on each new review
  ratingAvg   Decimal @default(0) @map("rating_avg") @db.Decimal(3, 2)
  reviewCount Int     @default(0) @map("review_count")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  partsBrand      PartsBrand             @relation(fields: [partsBrandId], references: [id])
  category        Category               @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  compatibilities ProductCompatibility[]
  reviews         Review[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  wishlistedBy    WishlistItem[]
  comparedBy      CompareItem[]

  @@index([sku])
  @@index([accountancyId])
  @@index([categoryId])
  @@index([partsBrandId])
  @@index([isActive, isOffer])
  @@index([saleCount])
  @@index([viewCount])
  @@index([searchText(ops: raw("gin_trgm_ops"))], type: Gin, map: "products_search_text_trgm_idx")
  @@map("products")
}

/// Additional product gallery images (beyond mainImage).
model ProductImage {
  id        String @id @default(cuid())
  productId String @map("product_id")
  url       String
  alt       String?
  sortOrder Int    @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

/// Many-to-many: a spare part can be compatible with multiple car models.
model ProductCompatibility {
  id         String @id @default(cuid())
  productId  String @map("product_id")
  carModelId Int    @map("car_model_id")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  carModel CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade)

  @@unique([productId, carModelId])
  @@index([productId])
  @@index([carModelId])
  @@map("product_compatibilities")
}

/// Customer review and star rating on a product.
model Review {
  id                 String   @id @default(cuid())
  productId          String   @map("product_id")
  /// Nullable — preserves display name even if the user account is deleted
  userId             String?  @map("user_id")
  authorName         String   @map("author_name")
  /// 1–5
  rating             Int
  text               String   @db.Text
  /// true only when the author has a completed order containing this product
  isVerifiedPurchase Boolean  @default(false) @map("is_verified_purchase")
  createdAt          DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────────────────────────────────────

/// One active cart per user — created lazily on first add-to-cart action.
model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at")

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// WISHLIST & COMPARE
// ─────────────────────────────────────────────────────────────────────────────

/// A product a user has saved for later. Independent of the cart — purely a
/// per-user bookmark. One row per (user, product); re-adding is a no-op.
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("wishlist_items")
}

/// A product a user has added to their side-by-side compare list. Same shape as
/// the wishlist but a separate concern; the app caps the active list size.
model CompareItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("compare_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// FAQ
// ─────────────────────────────────────────────────────────────────────────────

/// Blog posts — authored by admin; displayed on /blog and /blog/[slug].
model Post {
  id          Int      @id @default(autoincrement())
  /// URL-safe slug, e.g. "oil-change-guide"
  slug        String   @unique
  title       String
  excerpt     String   @db.Text
  /// HTML body — admin-authored content, never direct user input.
  body        String   @db.Text
  coverImage  String   @map("cover_image")
  author      String
  tags        String[]
  /// Estimated read time in minutes
  readTime    Int      @map("read_time")
  publishedAt DateTime @map("published_at")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([publishedAt])
  @@index([isPublished])
  @@map("posts")
}

/// Frequently-asked questions — admin-managed; displayed on the /faq page.
model Faq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("faqs")
}

// ─────────────────────────────────────────────────────────────────────────────
// SITE SETTINGS — singleton row, admin-managed
// ─────────────────────────────────────────────────────────────────────────────

/// Dynamic site info shown across the storefront (footer/contact/etc). Always a
/// single row — the app upserts `id = 1`.
model SiteSetting {
  id             Int      @id @default(1)
  phone          String?
  secondaryPhone String?  @map("secondary_phone")
  email          String?
  address        String?  @db.Text
  workingHours   String?  @map("working_hours")
  instagramUrl   String?  @map("instagram_url")
  telegramUrl    String?  @map("telegram_url")
  whatsappUrl    String?  @map("whatsapp_url")
  aboutText      String?  @db.Text @map("about_text")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// BULK SMS MARKETING — admin-managed
// ─────────────────────────────────────────────────────────────────────────────

/// One row per bulk SMS blast the admin sends («ارسال گروهی پیامک»). Snapshot
/// only — the recipient list itself isn't retained, just the counts, to keep
/// this table cheap and avoid storing phone numbers redundantly.
model SmsCampaign {
  id             String            @id @default(cuid())
  body           String            @db.Text
  targetRole     SmsTargetRole     @map("target_role")
  recipientCount Int               @default(0) @map("recipient_count")
  successCount   Int               @default(0) @map("success_count")
  failedCount    Int               @default(0) @map("failed_count")
  status         SmsCampaignStatus @default(PENDING)
  createdById    String?           @map("created_by_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  completedAt    DateTime?         @map("completed_at")

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("sms_campaigns")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────────────────────────────────────

/// Shipping methods and their current cost — editable by admin.
model ShippingOption {
  id          String         @id @default(cuid())
  method      ShippingMethod @unique
  label       String
  description String?
  cost        BigInt
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  orders Order[]

  @@map("shipping_options")
}

model Order {
  id               String         @id @default(cuid())
  /// Human-facing, sequential invoice number («شماره فاکتور») shown on the
  /// partner's orders list and printable invoice — distinct from the cuid `id`.
  orderNumber      Int            @unique @default(autoincrement()) @map("order_number")
  userId           String         @map("user_id")
  /// FK kept for history; address data also snapshotted below.
  addressId        String         @map("address_id")
  shippingOptionId String         @map("shipping_option_id")
  status           OrderStatus    @default(NEW)
  paymentMethod    PaymentMethod  @map("payment_method")
  paymentStatus    PaymentStatus  @default(PENDING) @map("payment_status")
  /// Free-text settlement terms chosen on the partner invoice (e.g. «چکی», «نقدی»,
  /// «اعتباری»). Complements the coarse `paymentMethod` enum used by retail checkout.
  paymentTerms     String?        @map("payment_terms")

  // ── Snapshotted delivery address ──────────────────────────────────────────
  // Copied at checkout so later edits to the address row don't affect history.
  snapshotProvince   String @map("snapshot_province")
  snapshotCity       String @map("snapshot_city")
  snapshotStreet     String @map("snapshot_street")
  snapshotPostalCode String @map("snapshot_postal_code")

  // ── Financials ─────────────────────────────────────────────────────────────
  subtotal     BigInt @map("subtotal")
  shippingCost BigInt @map("shipping_cost")
  /// VAT or other applicable tax collected on this order
  taxAmount    BigInt @default(0) @map("tax_amount")
  /// subtotal + shippingCost + taxAmount (stored to prevent drift)
  totalAmount  BigInt @map("total_amount")

  notes        String?
  trackingCode String?   @map("tracking_code")

  /// Zibal IPG session id — set when an online payment is initiated.
  paymentTrackId   BigInt?  @map("payment_track_id")
  /// Bank reference number returned by Zibal after a successful verify.
  paymentRefNumber String?  @map("payment_ref_number")

  paidAt      DateTime? @map("paid_at")
  shippedAt   DateTime? @map("shipped_at")
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id])
  address        Address        @relation(fields: [addressId], references: [id])
  shippingOption ShippingOption @relation(fields: [shippingOptionId], references: [id])
  items          OrderItem[]
  survey         OrderSurvey?

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String @map("order_id")
  productId String @map("product_id")

  // ── Immutable purchase snapshot ───────────────────────────────────────────
  productName     String  @map("product_name")
  productSku      String  @map("product_sku")
  /// Unit list price frozen at order time, before any line discount.
  priceAtPurchase BigInt @map("price_at_purchase")
  /// Percentage discount applied to this line (0–100) — e.g. the wholesale /
  /// cash discount on a partner invoice. 0 for plain retail lines. The net unit
  /// price is priceAtPurchase × (1 − discountPct / 100).
  discountPct     Decimal @default(0) @map("discount_pct") @db.Decimal(5, 2)
  /// Tax portion of this line item (e.g. VAT on priceAtPurchase × quantity)
  taxAmount       BigInt @default(0) @map("tax_amount")
  quantity        Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARTNER DASHBOARD
// ─────────────────────────────────────────────────────────────────────────────

/// Two-way support thread between a partner and the shop's support desk. A flat
/// message log (not threaded): the dashboard groups it into Inbox (INBOUND),
/// Sent (OUTBOUND) and Deleted (isDeleted) folders, with an unread badge on the
/// inbox. Soft-deleted messages move to the Deleted folder and can be restored.
model SupportMessage {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  direction MessageDirection
  subject   String
  body      String           @db.Text
  isRead    Boolean          @default(false) @map("is_read")
  isDeleted Boolean          @default(false) @map("is_deleted")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, direction, isDeleted])
  @@map("support_messages")
}

/// Post-purchase satisfaction survey — at most one per order («نظر سنجی»). The
/// positive/negative points are stored as the selected option keys (the fixed
/// option lists live in `src/lib/survey-options.ts`).
model OrderSurvey {
  id             String   @id @default(cuid())
  orderId        String   @unique @map("order_id")
  userId         String   @map("user_id")
  /// 1–5 stars.
  rating         Int
  positivePoints String[] @map("positive_points")
  negativePoints String[] @map("negative_points")
  note           String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("order_surveys")
}

/// A saved, filtered price-list request the partner can download as a printable
/// PDF («دریافت لیست قیمت»). The filter is snapshotted and the link is valid for
/// ~24h (expiresAt); after that the partner regenerates it. Empty filter arrays
/// mean "all" (all titles / brands / car models).
model PriceListRequest {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  /// Free-text product filters; fuzzy-matched against normalized name/SKU metadata. Empty = all.
  titles        String[]
  partsBrandIds Int[]    @map("parts_brand_ids")
  carModelIds   Int[]    @map("car_model_ids")
  createdAt     DateTime @default(now()) @map("created_at")
  expiresAt     DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("price_list_requests")
}

/// Wholesale partner suggestion to add a product to the shop catalogue
/// (درخواست تأمین کالا). Admin review comes later; for now this is append-only
/// storage keyed to the submitting user.
model ProductSuggestion {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  /// Free-text description of the product the partner wants stocked.
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("product_suggestions")
}

